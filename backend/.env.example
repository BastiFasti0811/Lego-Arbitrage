# ═══════════════════════════════════════════════════════
# LEGO Arbitrage System — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lego:lego_secret@postgres:5432/lego_arbitrage
DATABASE_URL_SYNC=postgresql://lego:lego_secret@postgres:5432/lego_arbitrage

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Scraper ──────────────────────────────────────────
SCRAPER_DELAY_MIN=2.0
SCRAPER_DELAY_MAX=5.0
# Optional: Bright Data or other proxy
# PROXY_URL=http://user:pass@proxy.brightdata.com:22225
USE_STEALTH_MODE=true

# ── AI Agent (Phase 3) ──────────────────────────────
# Get your key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
AI_MONTHLY_BUDGET_EUR=100.0

# ── Telegram Notifications ───────────────────────────
# Create bot via @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=123456789

# ── Email Notifications ─────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=app_password_here
# NOTIFICATION_EMAIL=your@email.com

# ── Dashboard Auth ────────────────────────────────────
DASHBOARD_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# ── General ──────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
MEDIA_ROOT=data
INVENTORY_PHOTO_MAX_COUNT=8
INVENTORY_PHOTO_MAX_BYTES=8388608
INVENTORY_PHOTO_MAX_DIMENSION=1600
INVENTORY_PHOTO_JPEG_QUALITY=82
